pipeline {
    agent any

    stages {
        stage('1. Setup Infrastructure') {
            steps {
                echo 'Starting app infrastructure (Redis, SonarQube)...'
                sh 'docker-compose -f docker-compose.yaml up -d'
            }
        }

        stage('2. Configure SonarQube Token') {
            steps {
                echo 'Generating SonarQube token inside Jenkins container...'
                sh 'python3 /opt/setup-jenkins/setup-jenkins.py'
                echo 'Reloading JCasC to pick up the new token...'
                sh 'curl -sf -X POST "http://localhost:8080/reload-configuration-as-code/?casc-reload-token=$(cat /var/jenkins_home/secrets/casc-reload-token 2>/dev/null || echo auto)"'
            }
        }

        stage('3. Install Dependencies') {
            steps {
                dir('node_sever') {
                    sh 'docker run --rm --volumes-from jenkins-server -w "$WORKSPACE/node_sever" node:22-bookworm-slim npm ci'
                }
            }
        }

        stage('4. Run Tests & Coverage') {
            steps {
                dir('node_sever') {
                    sh 'docker run --rm --volumes-from jenkins-server -w "$WORKSPACE/node_sever" node:22-bookworm-slim npm run test:coverage'
                }
            }
        }

        stage('5. SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'SonarScanner'
                    withSonarQubeEnv('MySonarServer') {
                        sh "${scannerHome}/bin/sonar-scanner -Dproject.settings=sonar/sonar-project.properties"
                    }
                }
            }
        }

        stage('6. Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('7. Build & Deploy') {
            steps {
                sh 'docker-compose -f docker-compose.yaml up -d --build'
                sh 'docker image prune -f'
            }
        }
    }

    post {
        success {
            echo 'All stages completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Please check the logs in the specific stage.'
        }
    }
}
