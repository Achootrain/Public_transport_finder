pipeline {
    agent any

    environment {
        COMPOSE_PROJECT = 'ptf-infra'
        COMPOSE_FILE    = 'docker-compose.yaml'
    }

    stages {
        stage('1. Setup Infrastructure') {
            steps {
                echo 'Starting Redis and SonarQube...'
                sh 'touch node_sever/.env'   // compose validates env_file for all services
                sh "docker-compose -p ${COMPOSE_PROJECT} -f ${COMPOSE_FILE} up -d redis sonar"

                echo 'Connecting Jenkins to the infrastructure network...'
                sh "docker network connect ${COMPOSE_PROJECT}_transit_net jenkins-server || true"
            }
        }

        stage('2. Configure SonarQube Token') {
            steps {
                echo 'Generating SonarQube token (waits for SonarQube health)...'
                sh 'python3 /opt/setup-jenkins/setup-jenkins.py'

                echo 'Reloading JCasC to pick up the new token...'
                sh '''
                    set -euo pipefail
                    cookieJar="$(mktemp)"
                    crumbJson="$(curl -sf -c "${cookieJar}" http://localhost:8080/crumbIssuer/api/json)"
                    crumbField="$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(d["crumbRequestField"])' <<<"${crumbJson}")"
                    crumbValue="$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(d["crumb"])' <<<"${crumbJson}")"
                    reloadToken="$(cat /var/jenkins_home/secrets/casc-reload-token 2>/dev/null || echo auto)"

                    curl -sf -b "${cookieJar}" \
                         -H "${crumbField}: ${crumbValue}" \
                         -X POST "http://localhost:8080/reload-configuration-as-code/?casc-reload-token=${reloadToken}"
                '''
            }
        }

        stage('3. Install Dependencies') {
            steps {
                sh '''
                    docker run --rm \
                        --user "$(id -u):$(id -g)" \
                        --env HOME=/tmp \
                        --volumes-from jenkins-server \
                        -w "$WORKSPACE/node_sever" \
                        node:22-bookworm-slim npm ci
                '''
            }
        }

        stage('4. Run Tests & Coverage') {
            steps {
                sh '''
                    docker run --rm \
                        --user "$(id -u):$(id -g)" \
                        --env HOME=/tmp \
                        --volumes-from jenkins-server \
                        --network ${COMPOSE_PROJECT}_transit_net \
                        -w "$WORKSPACE/node_sever" \
                        node:22-bookworm-slim npm run test:coverage
                '''
            }
        }

        stage('5. SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'SonarScanner'
                    withSonarQubeEnv('MySonarServer') {
                        sh "${scannerHome}/bin/sonar-scanner -Dproject.settings=sonar/sonar-project.properties"
                    }
                }
            }
        }

        stage('6. Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('7. Build & Deploy') {
            steps {
                sh "docker-compose -p ${COMPOSE_PROJECT} -f ${COMPOSE_FILE} up -d --build"
                sh 'docker image prune -f'
            }
        }
    }

    post {
        always {
            sh "docker network disconnect ${COMPOSE_PROJECT}_transit_net jenkins-server || true"
        }
        success {
            echo 'All stages completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Check the logs for the failing stage above.'
        }
    }
}
